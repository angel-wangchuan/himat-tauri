{
  "name": "himat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vue-tsc --noEmit && vp build",
    "preview": "vp preview",
    "tauri": "tauri",
    "sdk": "pnpm add ../himat-api-sdk",
    "sync-i18n": "node scripts/sync-i18n.mjs",
    "build:app": "node scripts/build.mjs",
    "build:app:macos": "node scripts/build.mjs -t macos",
    "build:app:macos-arm": "node scripts/build.mjs -t macos-aarch64",
    "build:app:windows": "node scripts/build.mjs -t windows",
    "build:app:linux": "node scripts/build.mjs -t linux",
    "build:app:debug": "node scripts/build.mjs -d",
    "updater:sign": "tauri signer sign -k .tauri/himat.key"
  },
  "dependencies": {
    "@himat/api-sdk": "link:../himat-api-sdk",
    "@internationalized/date": "^3.12.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-log": "~2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "~2",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.9.3",
    "tailwind-merge": "^3.5.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.31",
    "vue-i18n": "^11.3.2",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@iconify-json/radix-icons": "^1.2.6",
    "@iconify-json/ri": "^1.2.10",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "esbuild": "^0.24.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vite-plus": "latest",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
